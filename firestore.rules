// Firestore Security Rules
// Paste into Firebase Console > Firestore Database > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // A follow document is the proof that a follower/followee relationship
    // exists; the follower counts below are only allowed to move in step with it.
    function followDoc(followerUid, followedUid) {
      return /databases/$(database)/documents/follows/$(followerUid + '_' + followedUid);
    }

    // User profiles: public read, owner-only write — EXCEPT the reward fields
    // (points/streak/claim state), which only the trusted server may write via
    // the Admin SDK. This makes points impossible to grant from the client.
    // followersCount is excluded from self-writes too: it is not the owner's to
    // set, it moves only through the follow rule below.
    match /users/{userId} {
      allow read: if true;

      allow create: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.keys().hasAny(
                         ['points', 'streak', 'lastClaimAt', 'claimCount', 'lastClaimTxHash', 'completedTasks', 'taskTxHashes'])
                    && (!('followersCount' in request.resource.data) || request.resource.data.followersCount == 0);

      allow update: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
                         ['points', 'streak', 'lastClaimAt', 'claimCount', 'lastClaimTxHash', 'completedTasks', 'taskTxHashes',
                          'openPerpCount', 'perpWins', 'perpCount', 'followersCount']);

      // Following someone bumps their followersCount by one. Anyone could
      // otherwise inflate any profile, so the change must match a follow
      // document that this user actually owns: +1 only once it exists, -1 only
      // once it is gone. Nothing else in the profile may change.
      allow update: if request.auth != null && request.auth.uid != userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followersCount'])
                    && (
                         (request.resource.data.followersCount == resource.data.get('followersCount', 0) + 1
                          && exists(followDoc(request.auth.uid, userId)))
                         ||
                         (request.resource.data.followersCount == resource.data.get('followersCount', 0) - 1
                          && !exists(followDoc(request.auth.uid, userId)))
                       );
    }

    // Follow graph: one document per relationship, id "<follower>_<followed>".
    // Public read (profiles show follower lists); only the follower may create
    // or remove their own edge, and the id has to match who they claim to be.
    match /follows/{followId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.followerId == request.auth.uid
                    && request.resource.data.followingId is string
                    && request.resource.data.followerId != request.resource.data.followingId
                    && followId == request.auth.uid + '_' + request.resource.data.followingId;
      allow delete: if request.auth != null && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // Prediction markets: public read. A signed-in user may create a market they
    // own, with zeroed tallies and open status, and afterwards edit only its
    // descriptive fields (title, slug, info, sources).
    //
    // Everything that decides an outcome or describes standing is server-owned:
    // the tallies and volume come from the bet endpoint, and status/probability
    // /resolvedAt come from /api/admin-markets. A creator could otherwise
    // display any odds they liked, or settle their own market.
    //
    // The deadline can still be corrected, but only while nobody has predicted
    // yet — moving it under an open position would change the game mid-play.
    match /markets/{marketId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.creator == request.auth.uid
                    && request.resource.data.yesBets == 0
                    && request.resource.data.noBets == 0
                    && request.resource.data.get('volumeUSD', 0) == 0
                    && request.resource.data.status == 'open';

      allow update: if request.auth != null
                    && resource.data.creator == request.auth.uid
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
                         ['yesBets', 'noBets', 'creator', 'creatorProfile', 'volumeUSD', 'metrics',
                          'status', 'probability', 'resolvedAt', 'resolvedBy', 'previousStatus'])
                    && (
                         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['resolvesAt'])
                         || (resource.data.get('yesBets', 0) == 0 && resource.data.get('noBets', 0) == 0)
                       );

      allow delete: if request.auth != null && resource.data.creator == request.auth.uid;
    }

    // Probability history behind the market chart: public read, server-written.
    // A client that could write here could draw any price history it liked.
    match /prices/{pointId} {
      allow read: if true;
      allow write: if false;
    }

    // Social feed posts
    match /feed/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['uid', 'displayName', 'handle', 'text', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 500;
      allow update, delete: if request.auth != null
                             && resource.data.uid == request.auth.uid;
    }

    // Likes / reposts: one doc per user, keyed by uid
    match /feed/{postId}/likes/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /feed/{postId}/reposts/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Replies to feed posts
    match /feed/{postId}/replies/{replyId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['uid', 'text', 'createdAt'])
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 500;
      allow update, delete: if request.auth != null
                             && resource.data.uid == request.auth.uid;
    }

    // Market comments (userAddress holds the Firebase uid). A comment must be
    // signed by whoever is writing it — otherwise anyone could post under
    // someone else's name.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userAddress == request.auth.uid
                    && request.resource.data.marketId is string
                    && request.resource.data.content is string
                    && request.resource.data.content.size() <= 1000;
      allow update: if false;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.userAddress;
    }

    // News items: public read; writes only via the trusted admin endpoint
    // (server-only ADMIN_PASSWORD + Admin SDK). Not client-writable, so no one
    // can inject news/phishing items directly.
    match /news/{newsId} {
      allow read: if true;
      allow write: if false;
    }

    // Public news cache: public read for instant paint; writes only via the
    // trusted /api/news-cache endpoint (Admin), which writes the server's own
    // aggregated feed — so the cache can't be poisoned with injected items.
    match /newsCache/{view} {
      allow read: if true;
      allow write: if false;
    }

    // Market predictions: public read; only the trusted server (Admin SDK, which
    // bypasses rules) may write, after verifying the on-chain bet tx.
    match /bets/{betId} {
      allow read: if true;
      allow write: if false;
    }

    // Daily leaderboard tallies: public read; server-written only.
    match /dailyPoints/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Perp positions: readable only by their owner; only the trusted server
    // (Admin SDK) may write, since it escrows/pays points and fetches the
    // entry/exit prices itself.
    match /perpPositions/{positionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // Single-use guards keyed by transaction hash, written by the perp endpoint
    // to stop one on-chain tx from opening two positions. Server-only, and
    // there is nothing here worth reading from a client.
    match /perpTx/{txHash} {
      allow read, write: if false;
    }

    // Launches (Product Hunt-style): public read. A signed-in user may submit a
    // launch they own, with zeroed tallies, and edit only its descriptive
    // fields. The vote tallies (voteCount/voteWeight) are server-owned — only
    // the trusted /api/vote endpoint (Admin SDK, after on-chain verification)
    // may change them — so no one can inflate a ranking from the client.
    match /launches/{launchId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.submittedBy == request.auth.uid
                    && request.resource.data.voteCount == 0
                    && request.resource.data.voteWeight == 0
                    && request.resource.data.status == 'live';
      allow update: if request.auth != null
                    && resource.data.submittedBy == request.auth.uid
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
                         ['voteCount', 'voteWeight', 'submittedBy', 'status']);
      allow delete: if request.auth != null && resource.data.submittedBy == request.auth.uid;
    }

    // Launch votes: public read (so tallies/who-voted can be shown); only the
    // trusted server may write, after verifying the on-chain vote tx and
    // snapshotting the voter's stake power. Voting never spends points.
    match /launchVotes/{voteId} {
      allow read: if true;
      allow write: if false;
    }

    // Anything not matched above stays denied.
  }
}
